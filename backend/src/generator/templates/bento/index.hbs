<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="bento">

    <!-- Identity card -->
    <div class="card card-identity">
      <h1 class="identity-name">{{name}}</h1>
      {{#if summary}}<p class="identity-summary">{{summary}}</p>{{/if}}
    </div>

    <!-- Contact card -->
    <div class="card card-contact">
      <h2 class="card-title">Contact</h2>
      <ul class="contact-list">
        {{#if email}}<li><span class="label">Email</span><a href="mailto:{{email}}">{{email}}</a></li>{{/if}}
        {{#if phone}}<li><span class="label">Phone</span><span>{{phone}}</span></li>{{/if}}
        {{#if location}}<li><span class="label">Location</span><span>{{location}}</span></li>{{/if}}
        {{#if linkedin}}<li><span class="label">LinkedIn</span><a href="https://{{linkedin}}" target="_blank" rel="noopener">{{linkedin}}</a></li>{{/if}}
        {{#if website}}<li><span class="label">Website</span><a href="{{website}}" target="_blank" rel="noopener">{{website}}</a></li>{{/if}}
      </ul>
    </div>

    {{#if (hasItems skills)}}
    <!-- Skills card -->
    <div class="card card-skills">
      <h2 class="card-title">Skills</h2>
      <div class="skill-pills">
        {{#each skills}}<span class="pill">{{this}}</span>{{/each}}
      </div>
    </div>
    {{/if}}

    {{#if (hasItems experience)}}
    <!-- Experience card -->
    <div class="card card-experience">
      <h2 class="card-title">Experience</h2>
      {{#each experience}}
      <div class="exp-item">
        <div class="exp-top">
          <div>
            <div class="exp-title">{{title}}</div>
            <div class="exp-company">{{company}}</div>
          </div>
          <span class="exp-date">{{dateRange startDate endDate}}</span>
        </div>
        {{#if (hasItems bullets)}}
        <ul class="exp-bullets">
          {{#each bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if (hasItems education)}}
    <!-- Education card -->
    <div class="card card-education">
      <h2 class="card-title">Education</h2>
      {{#each education}}
      <div class="edu-item">
        <div class="edu-top">
          <div class="edu-inst">{{institution}}</div>
          {{#if startDate}}<span class="edu-date">{{dateRange startDate endDate}}</span>{{/if}}
        </div>
        {{#if degree}}<div class="edu-degree">{{degree}}{{#if field}} in {{field}}{{/if}}</div>{{/if}}
        {{#if gpa}}<div class="edu-gpa">GPA: {{gpa}}</div>{{/if}}
      </div>
      {{/each}}
    </div>
    {{/if}}

  </div>
</body>
</html>
