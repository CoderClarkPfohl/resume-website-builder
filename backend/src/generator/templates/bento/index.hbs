<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="bento">

    <!-- Identity card -->
    <div class="card card-identity">
      <h1 class="identity-name">{{name}}</h1>
      <div class="identity-contact">
        {{#if email}}<a href="mailto:{{email}}">{{email}}</a>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if github}}<a href="https://{{github}}" target="_blank" rel="noopener">GitHub</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
    </div>

    {{#each activeSections}}
    <div class="card {{#if (eq this.type 'list')}}card-list{{/if}} {{#if (eq this.type 'text')}}card-text{{/if}} {{#if (eq this.type 'experience')}}card-wide{{/if}} {{#if (eq this.type 'education')}}card-wide{{/if}} {{#if (eq this.type 'entries')}}card-wide{{/if}}">
      <h2 class="card-title">{{this.title}}</h2>

      {{#if (eq this.type "text")}}
      <p class="card-body-text">{{this.textContent}}</p>
      {{/if}}

      {{#if (eq this.type "list")}}
      <div class="skill-pills">
        {{#each this.listItems}}<span class="pill">{{this}}</span>{{/each}}
      </div>
      {{/if}}

      {{#if (eq this.type "experience")}}
      {{#each this.entries}}
      <div class="exp-item">
        <div class="exp-top">
          <div>
            <div class="exp-title">{{this.heading}}</div>
            {{#if this.subheading}}<div class="exp-company">{{this.subheading}}</div>{{/if}}
          </div>
          {{#if this.date}}<span class="exp-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if (hasItems this.bullets)}}
        <ul class="exp-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "education")}}
      {{#each this.entries}}
      <div class="edu-item">
        <div class="edu-top">
          <div class="edu-inst">{{this.heading}}</div>
          {{#if this.date}}<span class="edu-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if this.subheading}}<div class="edu-degree">{{this.subheading}}</div>{{/if}}
        {{#if (hasItems this.bullets)}}
        <ul class="exp-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "entries")}}
      {{#each this.entries}}
      <div class="exp-item">
        <div class="exp-top">
          <div>
            <div class="exp-title">{{this.heading}}</div>
            {{#if this.subheading}}<div class="exp-company">{{this.subheading}}</div>{{/if}}
          </div>
          {{#if this.date}}<span class="exp-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if (hasItems this.bullets)}}
        <ul class="exp-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

    </div>
    {{/each}}

  </div>
</body>
</html>
