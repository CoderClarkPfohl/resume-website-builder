<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="resume">

    <!-- Header -->
    <header class="resume-header">
      <h1>{{name}}</h1>
      <div class="contact-line">
        {{#if email}}<a href="mailto:{{email}}">{{email}}</a>{{/if}}
        {{#if email}}{{#if phone}}<span class="contact-sep">|</span>{{/if}}{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}{{#if phone}}<span class="contact-sep">|</span>{{/if}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<span class="contact-sep">|</span><a href="https://{{linkedin}}" target="_blank" rel="noopener">{{linkedin}}</a>{{/if}}
        {{#if website}}<span class="contact-sep">|</span><a href="{{website}}" target="_blank" rel="noopener">{{website}}</a>{{/if}}
      </div>
    </header>

    <!-- Summary -->
    {{#if summary}}
    <section class="section summary">
      <h2 class="section-title">Summary</h2>
      <p>{{summary}}</p>
    </section>
    {{/if}}

    <!-- Experience -->
    {{#if (hasItems experience)}}
    <section class="section">
      <h2 class="section-title">Experience</h2>
      {{#each experience}}
      <div class="job">
        <div class="job-header">
          <span class="job-company">{{company}}</span>
          <span class="job-dates">{{dateRange startDate endDate}}</span>
        </div>
        {{#if title}}<div class="job-title">{{title}}</div>{{/if}}
        {{#if location}}<div class="job-location">{{location}}</div>{{/if}}
        {{#if (hasItems bullets)}}
        <ul class="job-bullets">
          {{#each bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    <!-- Education -->
    {{#if (hasItems education)}}
    <section class="section">
      <h2 class="section-title">Education</h2>
      {{#each education}}
      <div class="edu-item">
        <div class="edu-header">
          <span class="edu-institution">{{institution}}</span>
          {{#if startDate}}<span class="edu-dates">{{dateRange startDate endDate}}</span>{{/if}}
        </div>
        {{#if degree}}<div class="edu-degree">{{degree}}{{#if field}} in {{field}}{{/if}}</div>{{/if}}
        {{#if gpa}}<div class="edu-gpa">GPA: {{gpa}}</div>{{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    <!-- Skills -->
    {{#if (hasItems skills)}}
    <section class="section">
      <h2 class="section-title">Skills</h2>
      <div class="skills-list">{{join skills ", "}}</div>
    </section>
    {{/if}}

  </div>
</body>
</html>
