<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="resume">

    <!-- Header -->
    <header class="resume-header">
      <h1>{{name}}</h1>
      <div class="contact-line">
        {{#if email}}<a href="mailto:{{email}}">{{email}}</a>{{/if}}
        {{#if email}}{{#if phone}}<span class="contact-sep">|</span>{{/if}}{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}{{#if phone}}<span class="contact-sep">|</span>{{/if}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<span class="contact-sep">|</span><a href="https://{{linkedin}}" target="_blank" rel="noopener">{{linkedin}}</a>{{/if}}
        {{#if github}}<span class="contact-sep">|</span><a href="https://{{github}}" target="_blank" rel="noopener">{{github}}</a>{{/if}}
        {{#if website}}<span class="contact-sep">|</span><a href="{{website}}" target="_blank" rel="noopener">{{website}}</a>{{/if}}
      </div>
    </header>

    {{#each activeSections}}
    <section class="section">
      <h2 class="section-title">{{this.title}}</h2>

      {{#if (eq this.type "text")}}
      <p>{{this.textContent}}</p>
      {{/if}}

      {{#if (eq this.type "list")}}
      <div class="skills-list">{{join this.listItems ", "}}</div>
      {{/if}}

      {{#if (eq this.type "experience")}}
      {{#each this.entries}}
      <div class="job">
        <div class="job-header">
          <span class="job-company">{{this.heading}}</span>
          {{#if this.date}}<span class="job-dates">{{this.date}}</span>{{/if}}
        </div>
        {{#if this.subheading}}<div class="job-title">{{this.subheading}}</div>{{/if}}
        {{#if (hasItems this.bullets)}}
        <ul class="job-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "education")}}
      {{#each this.entries}}
      <div class="edu-item">
        <div class="edu-header">
          <span class="edu-institution">{{this.heading}}</span>
          {{#if this.date}}<span class="edu-dates">{{this.date}}</span>{{/if}}
        </div>
        {{#if this.subheading}}<div class="edu-degree">{{this.subheading}}</div>{{/if}}
        {{#if (hasItems this.bullets)}}
        <ul class="job-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "entries")}}
      {{#each this.entries}}
      <div class="job">
        <div class="job-header">
          <span class="job-company">{{this.heading}}</span>
          {{#if this.date}}<span class="job-dates">{{this.date}}</span>{{/if}}
        </div>
        {{#if this.subheading}}<div class="job-title">{{this.subheading}}</div>{{/if}}
        {{#if (hasItems this.bullets)}}
        <ul class="job-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

    </section>
    {{/each}}

  </div>
</body>
</html>
