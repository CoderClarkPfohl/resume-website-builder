<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="page">

    <header class="hero">
      <h1 class="hero-name">{{name}}</h1>
      <div class="hero-contact">
        {{#if email}}<a href="mailto:{{email}}">{{email}}</a>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Portfolio</a>{{/if}}
      </div>
    </header>

    {{#each activeSections}}
    <section class="section">
      <h2 class="section-title">{{this.title}}</h2>

      {{#if (eq this.type "text")}}
      <p class="hero-summary">{{this.textContent}}</p>
      {{/if}}

      {{#if (eq this.type "list")}}
      <div class="skill-tags">
        {{#each this.listItems}}<span class="skill-tag">{{this}}</span>{{/each}}
      </div>
      {{/if}}

      {{#if (eq this.type "experience")}}
      <div class="timeline">
        {{#each this.entries}}
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <div class="timeline-role">{{this.heading}}</div>
                {{#if this.subheading}}<div class="timeline-company">{{this.subheading}}</div>{{/if}}
              </div>
              {{#if this.date}}<span class="timeline-date">{{this.date}}</span>{{/if}}
            </div>
            {{#if (hasItems this.bullets)}}
            <ul class="timeline-bullets">
              {{#each this.bullets}}<li>{{this}}</li>{{/each}}
            </ul>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if (eq this.type "education")}}
      {{#each this.entries}}
      <div class="edu-row">
        <div>
          <div class="edu-inst">{{this.heading}}</div>
          {{#if this.subheading}}<div class="edu-degree">{{this.subheading}}</div>{{/if}}
          {{#if (hasItems this.bullets)}}
          <ul class="timeline-bullets">
            {{#each this.bullets}}<li>{{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{#if this.date}}<span class="edu-date">{{this.date}}</span>{{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "entries")}}
      <div class="timeline">
        {{#each this.entries}}
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <div class="timeline-role">{{this.heading}}</div>
                {{#if this.subheading}}<div class="timeline-company">{{this.subheading}}</div>{{/if}}
              </div>
              {{#if this.date}}<span class="timeline-date">{{this.date}}</span>{{/if}}
            </div>
            {{#if (hasItems this.bullets)}}
            <ul class="timeline-bullets">
              {{#each this.bullets}}<li>{{this}}</li>{{/each}}
            </ul>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

    </section>
    {{/each}}

  </div>
</body>
</html>
