<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}}</title>
  <link rel="stylesheet" href="style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
</head>
<body>
  <article class="page">

    <header class="masthead">
      <div class="dateline">Curriculum Vitae</div>
      <h1 class="masthead-name">{{name}}</h1>
      <div class="masthead-rule"></div>
      <div class="masthead-contact">
        {{#if email}}<span>{{email}}</span>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
    </header>

    {{#if summary}}
    <section class="lede">
      <p>{{summary}}</p>
    </section>
    {{/if}}

    {{#if (hasItems experience)}}
    <section class="section">
      <h2 class="section-head">Experience</h2>
      {{#each experience}}
      <div class="story">
        <div class="story-kicker">{{dateRange startDate endDate}}{{#if location}} · {{location}}{{/if}}</div>
        <h3 class="story-headline">{{title}}</h3>
        <div class="story-byline">{{company}}</div>
        {{#if (hasItems bullets)}}
        <ul class="story-body">
          {{#each bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if (hasItems education)}}
    <section class="section">
      <h2 class="section-head">Education</h2>
      {{#each education}}
      <div class="story">
        <div class="story-kicker">{{dateRange startDate endDate}}</div>
        <h3 class="story-headline">{{institution}}</h3>
        {{#if degree}}<div class="story-byline">{{degree}}{{#if field}} in {{field}}{{/if}}</div>{{/if}}
        {{#if gpa}}<div class="story-note">GPA: {{gpa}}</div>{{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if (hasItems skills)}}
    <section class="section">
      <h2 class="section-head">Skills</h2>
      <p class="skills-prose">{{join skills " · "}}</p>
    </section>
    {{/if}}

    <footer class="colophon">
      <div class="masthead-rule"></div>
    </footer>

  </article>
</body>
</html>
