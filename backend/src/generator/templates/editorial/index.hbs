<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}}</title>
  <link rel="stylesheet" href="style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
</head>
<body>
  <article class="page">

    <header class="masthead">
      <div class="dateline">Curriculum Vitae</div>
      <h1 class="masthead-name">{{name}}</h1>
      <div class="masthead-rule"></div>
      <div class="masthead-contact">
        {{#if email}}<span>{{email}}</span>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if github}}<a href="https://{{github}}" target="_blank" rel="noopener">GitHub</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
    </header>

    {{#each activeSections}}
    <section class="section">
      {{#if (eq this.type "text")}}
      <div class="lede"><p>{{this.textContent}}</p></div>
      {{else}}
      <h2 class="section-head">{{this.title}}</h2>
      {{/if}}

      {{#if (eq this.type "list")}}
      <p class="skills-prose">{{join this.listItems " · "}}</p>
      {{/if}}

      {{#if (eq this.type "experience")}}
      {{#each this.entries}}
      <div class="story">
        <div class="story-kicker">{{this.date}}{{#if this.subheading}} · {{this.subheading}}{{/if}}</div>
        <h3 class="story-headline">{{this.heading}}</h3>
        {{#if (hasItems this.bullets)}}
        <ul class="story-body">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "education")}}
      {{#each this.entries}}
      <div class="story">
        {{#if this.date}}<div class="story-kicker">{{this.date}}</div>{{/if}}
        <h3 class="story-headline">{{this.heading}}</h3>
        {{#if this.subheading}}<div class="story-byline">{{this.subheading}}</div>{{/if}}
        {{#if (hasItems this.bullets)}}
        <ul class="story-body">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "entries")}}
      {{#each this.entries}}
      <div class="story">
        {{#if this.date}}<div class="story-kicker">{{this.date}}</div>{{/if}}
        <h3 class="story-headline">{{this.heading}}</h3>
        {{#if this.subheading}}<div class="story-byline">{{this.subheading}}</div>{{/if}}
        {{#if (hasItems this.bullets)}}
        <ul class="story-body">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

    </section>
    {{/each}}

    <footer class="colophon">
      <div class="masthead-rule"></div>
    </footer>

  </article>
</body>
</html>
