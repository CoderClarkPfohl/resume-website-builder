<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <div class="page">

    <div class="glass-card hero-card">
      <h1 class="hero-name">{{name}}</h1>
      <div class="hero-contact">
        {{#if email}}<a href="mailto:{{email}}">{{email}}</a>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
    </div>

    {{#each activeSections}}
    <div class="glass-card">
      <h2 class="card-title">{{this.title}}</h2>

      {{#if (eq this.type "text")}}
      <p class="hero-summary">{{this.textContent}}</p>
      {{/if}}

      {{#if (eq this.type "list")}}
      <div class="skill-chips">
        {{#each this.listItems}}<span class="chip">{{this}}</span>{{/each}}
      </div>
      {{/if}}

      {{#if (eq this.type "experience")}}
      {{#each this.entries}}
      <div class="exp-item">
        <div class="exp-header">
          <div>
            <div class="exp-role">{{this.heading}}</div>
            {{#if this.subheading}}<div class="exp-company">{{this.subheading}}</div>{{/if}}
          </div>
          {{#if this.date}}<span class="exp-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if (hasItems this.bullets)}}
        <ul class="exp-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "education")}}
      {{#each this.entries}}
      <div class="edu-item">
        <div class="edu-inst">{{this.heading}}</div>
        {{#if this.subheading}}<div class="edu-degree">{{this.subheading}}</div>{{/if}}
        {{#if this.date}}<div class="edu-date">{{this.date}}</div>{{/if}}
        {{#if (hasItems this.bullets)}}
        <ul class="exp-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "entries")}}
      {{#each this.entries}}
      <div class="exp-item">
        <div class="exp-header">
          <div>
            <div class="exp-role">{{this.heading}}</div>
            {{#if this.subheading}}<div class="exp-company">{{this.subheading}}</div>{{/if}}
          </div>
          {{#if this.date}}<span class="exp-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if (hasItems this.bullets)}}
        <ul class="exp-bullets">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

    </div>
    {{/each}}

  </div>
</body>
</html>
