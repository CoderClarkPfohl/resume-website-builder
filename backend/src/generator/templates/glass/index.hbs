<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <div class="page">

    <div class="glass-card hero-card">
      <h1 class="hero-name">{{name}}</h1>
      <div class="hero-contact">
        {{#if email}}<a href="mailto:{{email}}">{{email}}</a>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
      {{#if summary}}
      <p class="hero-summary">{{summary}}</p>
      {{/if}}
    </div>

    {{#if (hasItems experience)}}
    <div class="glass-card">
      <h2 class="card-title">Experience</h2>
      {{#each experience}}
      <div class="exp-item">
        <div class="exp-header">
          <div>
            <div class="exp-role">{{title}}</div>
            <div class="exp-company">{{company}}{{#if location}} · {{location}}{{/if}}</div>
          </div>
          <span class="exp-date">{{dateRange startDate endDate}}</span>
        </div>
        {{#if (hasItems bullets)}}
        <ul class="exp-bullets">
          {{#each bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{/if}}

    <div class="two-col">
      {{#if (hasItems education)}}
      <div class="glass-card">
        <h2 class="card-title">Education</h2>
        {{#each education}}
        <div class="edu-item">
          <div class="edu-inst">{{institution}}</div>
          {{#if degree}}<div class="edu-degree">{{degree}}{{#if field}} in {{field}}{{/if}}</div>{{/if}}
          {{#if startDate}}<div class="edu-date">{{dateRange startDate endDate}}</div>{{/if}}
          {{#if gpa}}<div class="edu-gpa">GPA: {{gpa}}</div>{{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if (hasItems skills)}}
      <div class="glass-card">
        <h2 class="card-title">Skills</h2>
        <div class="skill-chips">
          {{#each skills}}<span class="chip">{{this}}</span>{{/each}}
        </div>
      </div>
      {{/if}}
    </div>

  </div>
</body>
</html>
