<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}}</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="page">

    <header class="header">
      <h1 class="name">{{name}}</h1>
      <div class="contact-line">
        {{#if email}}<span>{{email}}</span>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
    </header>

    {{#each activeSections}}
    <section class="section">
      {{#if (eq this.type "text")}}
      <p class="summary-text">{{this.textContent}}</p>
      {{else}}
      <h2 class="section-heading">{{this.title}}</h2>
      {{/if}}

      {{#if (eq this.type "list")}}
      <p class="skills-text">{{join this.listItems ", "}}</p>
      {{/if}}

      {{#if (eq this.type "experience")}}
      {{#each this.entries}}
      <div class="entry">
        <div class="entry-row">
          <div>
            <span class="entry-primary">{{this.heading}}</span>
            {{#if this.subheading}}<span class="entry-secondary">{{this.subheading}}</span>{{/if}}
          </div>
          {{#if this.date}}<span class="entry-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if (hasItems this.bullets)}}
        <ul class="entry-list">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "education")}}
      {{#each this.entries}}
      <div class="entry">
        <div class="entry-row">
          <div>
            <span class="entry-primary">{{this.heading}}</span>
            {{#if this.subheading}}<span class="entry-secondary">{{this.subheading}}</span>{{/if}}
          </div>
          {{#if this.date}}<span class="entry-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if (hasItems this.bullets)}}
        <ul class="entry-list">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq this.type "entries")}}
      {{#each this.entries}}
      <div class="entry">
        <div class="entry-row">
          <div>
            <span class="entry-primary">{{this.heading}}</span>
            {{#if this.subheading}}<span class="entry-secondary">{{this.subheading}}</span>{{/if}}
          </div>
          {{#if this.date}}<span class="entry-date">{{this.date}}</span>{{/if}}
        </div>
        {{#if (hasItems this.bullets)}}
        <ul class="entry-list">
          {{#each this.bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
      {{/if}}

    </section>
    {{/each}}

  </div>
</body>
</html>
