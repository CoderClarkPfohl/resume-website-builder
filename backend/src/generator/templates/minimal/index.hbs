<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}}</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="page">

    <header class="header">
      <h1 class="name">{{name}}</h1>
      <div class="contact-line">
        {{#if email}}<span>{{email}}</span>{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if location}}<span>{{location}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
    </header>

    {{#if summary}}
    <section class="section">
      <p class="summary-text">{{summary}}</p>
    </section>
    {{/if}}

    {{#if (hasItems experience)}}
    <section class="section">
      <h2 class="section-heading">Experience</h2>
      {{#each experience}}
      <div class="entry">
        <div class="entry-row">
          <div>
            <span class="entry-primary">{{title}}</span>
            {{#if company}}<span class="entry-secondary">{{company}}</span>{{/if}}
          </div>
          <span class="entry-date">{{dateRange startDate endDate}}</span>
        </div>
        {{#if location}}<div class="entry-location">{{location}}</div>{{/if}}
        {{#if (hasItems bullets)}}
        <ul class="entry-list">
          {{#each bullets}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if (hasItems education)}}
    <section class="section">
      <h2 class="section-heading">Education</h2>
      {{#each education}}
      <div class="entry">
        <div class="entry-row">
          <div>
            <span class="entry-primary">{{institution}}</span>
            {{#if degree}}<span class="entry-secondary">{{degree}}{{#if field}} in {{field}}{{/if}}</span>{{/if}}
          </div>
          {{#if startDate}}<span class="entry-date">{{dateRange startDate endDate}}</span>{{/if}}
        </div>
        {{#if gpa}}<div class="entry-location">GPA: {{gpa}}</div>{{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if (hasItems skills)}}
    <section class="section">
      <h2 class="section-heading">Skills</h2>
      <p class="skills-text">{{join skills ", "}}</p>
    </section>
    {{/if}}

  </div>
</body>
</html>
