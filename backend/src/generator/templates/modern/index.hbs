<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="resume">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-name">{{name}}</div>
      <hr class="sidebar-divider" />

      <div class="sidebar-contact">
        {{#if email}}
        <div class="contact-item">
          <i class="icon">✉</i>
          <a href="mailto:{{email}}">{{email}}</a>
        </div>
        {{/if}}
        {{#if phone}}
        <div class="contact-item">
          <i class="icon">☎</i>
          <span>{{phone}}</span>
        </div>
        {{/if}}
        {{#if location}}
        <div class="contact-item">
          <i class="icon">⌖</i>
          <span>{{location}}</span>
        </div>
        {{/if}}
        {{#if linkedin}}
        <div class="contact-item">
          <i class="icon">in</i>
          <a href="https://{{linkedin}}" target="_blank" rel="noopener">{{linkedin}}</a>
        </div>
        {{/if}}
        {{#if website}}
        <div class="contact-item">
          <i class="icon">⌘</i>
          <a href="{{website}}" target="_blank" rel="noopener">{{website}}</a>
        </div>
        {{/if}}
      </div>

      <!-- Sidebar list sections (skills, tools, languages, etc.) -->
      {{#each activeSections}}
      {{#if (eq this.type "list")}}
      <div class="sidebar-section">
        <div class="sidebar-section-title">{{this.title}}</div>
        <div class="skills-chips">
          {{#each this.listItems}}<span class="skill-chip">{{this}}</span>{{/each}}
        </div>
      </div>
      {{/if}}
      {{/each}}
    </aside>

    <!-- Main content -->
    <main class="main">

      {{#each activeSections}}
      {{#if (eq this.type "text")}}
      <section class="section summary">
        <h2 class="section-title">{{this.title}}</h2>
        <p>{{this.textContent}}</p>
      </section>
      {{/if}}

      {{#if (eq this.type "experience")}}
      <section class="section">
        <h2 class="section-title">{{this.title}}</h2>
        {{#each this.entries}}
        <div class="job">
          <div class="job-header">
            <span class="job-company">{{this.heading}}</span>
            {{#if this.date}}<span class="job-dates">{{this.date}}</span>{{/if}}
          </div>
          {{#if this.subheading}}<div class="job-title">{{this.subheading}}</div>{{/if}}
          {{#if (hasItems this.bullets)}}
          <ul class="job-bullets">
            {{#each this.bullets}}<li>{{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
      </section>
      {{/if}}

      {{#if (eq this.type "education")}}
      <section class="section">
        <h2 class="section-title">{{this.title}}</h2>
        {{#each this.entries}}
        <div class="edu-item">
          <div class="edu-header">
            <span class="edu-institution">{{this.heading}}</span>
            {{#if this.date}}<span class="edu-dates">{{this.date}}</span>{{/if}}
          </div>
          {{#if this.subheading}}<div class="edu-degree">{{this.subheading}}</div>{{/if}}
          {{#if (hasItems this.bullets)}}
          <ul class="job-bullets">
            {{#each this.bullets}}<li>{{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
      </section>
      {{/if}}

      {{#if (eq this.type "entries")}}
      <section class="section">
        <h2 class="section-title">{{this.title}}</h2>
        {{#each this.entries}}
        <div class="job">
          <div class="job-header">
            <span class="job-company">{{this.heading}}</span>
            {{#if this.date}}<span class="job-dates">{{this.date}}</span>{{/if}}
          </div>
          {{#if this.subheading}}<div class="job-title">{{this.subheading}}</div>{{/if}}
          {{#if (hasItems this.bullets)}}
          <ul class="job-bullets">
            {{#each this.bullets}}<li>{{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
      </section>
      {{/if}}
      {{/each}}

    </main>
  </div>
</body>
</html>
