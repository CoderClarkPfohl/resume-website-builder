<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>~{{name}}'s Homepage~</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="page">

    <div class="window">
      <div class="title-bar">
        <div class="title-bar-text">{{name}}_resume.html</div>
        <div class="title-bar-controls">
          <span class="btn-ctrl">_</span>
          <span class="btn-ctrl">□</span>
          <span class="btn-ctrl btn-close">×</span>
        </div>
      </div>
      <div class="window-body">

        <div class="marquee-bar">
          <span class="marquee-text">★ Welcome to {{name}}'s Personal Homepage ★</span>
        </div>

        <div class="hero-banner">
          <h1 class="hero-name">{{name}}</h1>
          <div class="hero-contact">
            {{#if email}}<span>📧 {{email}}</span>{{/if}}
            {{#if phone}}<span>📞 {{phone}}</span>{{/if}}
            {{#if location}}<span>📍 {{location}}</span>{{/if}}
            {{#if linkedin}}<span>🔗 <a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a></span>{{/if}}
            {{#if github}}<span>💻 <a href="https://{{github}}" target="_blank" rel="noopener">GitHub</a></span>{{/if}}
            {{#if website}}<span>🌐 <a href="{{website}}" target="_blank" rel="noopener">Website</a></span>{{/if}}
          </div>
        </div>

        {{#each activeSections}}
        <div class="panel">
          <div class="panel-header">📋 {{this.title}}</div>
          <div class="panel-body">

            {{#if (eq this.type "text")}}
            <p>{{this.textContent}}</p>
            {{/if}}

            {{#if (eq this.type "list")}}
            <div class="retro-skills">
              {{#each this.listItems}}<span class="retro-skill">{{this}}</span>{{/each}}
            </div>
            {{/if}}

            {{#if (eq this.type "experience")}}
            {{#each this.entries}}
            <div class="retro-entry">
              <div class="retro-entry-header">
                <span class="retro-bullet">▶</span>
                <strong>{{this.heading}}</strong>
                {{#if this.subheading}} @ {{this.subheading}}{{/if}}
                {{#if this.date}}<span class="retro-date">[{{this.date}}]</span>{{/if}}
              </div>
              {{#if (hasItems this.bullets)}}
              <ul class="retro-list">
                {{#each this.bullets}}<li>{{this}}</li>{{/each}}
              </ul>
              {{/if}}
            </div>
            {{/each}}
            {{/if}}

            {{#if (eq this.type "education")}}
            {{#each this.entries}}
            <div class="retro-entry">
              <div class="retro-entry-header">
                <span class="retro-bullet">▶</span>
                <strong>{{this.heading}}</strong>
                {{#if this.date}}<span class="retro-date">[{{this.date}}]</span>{{/if}}
              </div>
              {{#if this.subheading}}<div class="retro-detail">{{this.subheading}}</div>{{/if}}
              {{#if (hasItems this.bullets)}}
              <ul class="retro-list">
                {{#each this.bullets}}<li>{{this}}</li>{{/each}}
              </ul>
              {{/if}}
            </div>
            {{/each}}
            {{/if}}

            {{#if (eq this.type "entries")}}
            {{#each this.entries}}
            <div class="retro-entry">
              <div class="retro-entry-header">
                <span class="retro-bullet">▶</span>
                <strong>{{this.heading}}</strong>
                {{#if this.subheading}} — {{this.subheading}}{{/if}}
                {{#if this.date}}<span class="retro-date">[{{this.date}}]</span>{{/if}}
              </div>
              {{#if (hasItems this.bullets)}}
              <ul class="retro-list">
                {{#each this.bullets}}<li>{{this}}</li>{{/each}}
              </ul>
              {{/if}}
            </div>
            {{/each}}
            {{/if}}

          </div>
        </div>
        {{/each}}

        <div class="footer-bar">
          <span>🔧 Best viewed in any browser</span>
          <span>⭐ You are visitor #{{visitorCount}}</span>
        </div>

      </div>
    </div>
  </div>
</body>
</html>
