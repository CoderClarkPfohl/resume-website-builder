<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Resume</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="layout">

    <aside class="side">
      <div class="side-inner">
        <div class="avatar">{{name.[0]}}</div>
        <h1 class="side-name">{{name}}</h1>

        <nav class="side-nav">
          {{#each activeSections}}
          <a href="#section-{{@index}}">{{this.title}}</a>
          {{/each}}
        </nav>

        <div class="side-contact">
          {{#if email}}<div class="side-item"><span class="side-label">Email</span><a href="mailto:{{email}}">{{email}}</a></div>{{/if}}
          {{#if phone}}<div class="side-item"><span class="side-label">Phone</span><span>{{phone}}</span></div>{{/if}}
          {{#if location}}<div class="side-item"><span class="side-label">Location</span><span>{{location}}</span></div>{{/if}}
          {{#if linkedin}}<div class="side-item"><span class="side-label">LinkedIn</span><a href="https://{{linkedin}}" target="_blank" rel="noopener">Profile</a></div>{{/if}}
          {{#if github}}<div class="side-item"><span class="side-label">GitHub</span><a href="https://{{github}}" target="_blank" rel="noopener">{{github}}</a></div>{{/if}}
          {{#if website}}<div class="side-item"><span class="side-label">Website</span><a href="{{website}}" target="_blank" rel="noopener">Visit</a></div>{{/if}}
        </div>
      </div>
    </aside>

    <main class="content">

      {{#each activeSections}}
      <section id="section-{{@index}}" class="sect">
        <h2 class="sect-title">{{this.title}}</h2>

        {{#if (eq this.type "text")}}
        <p class="about-text">{{this.textContent}}</p>
        {{/if}}

        {{#if (eq this.type "list")}}
        <div class="skill-bars">
          {{#each this.listItems}}<span class="skill-bar">{{this}}</span>{{/each}}
        </div>
        {{/if}}

        {{#if (eq this.type "experience")}}
        {{#each this.entries}}
        <div class="exp-card">
          <div class="exp-top">
            <div>
              <div class="exp-role">{{this.heading}}</div>
              {{#if this.subheading}}<div class="exp-company">{{this.subheading}}</div>{{/if}}
            </div>
            {{#if this.date}}<div class="exp-date">{{this.date}}</div>{{/if}}
          </div>
          {{#if (hasItems this.bullets)}}
          <ul class="exp-bullets">
            {{#each this.bullets}}<li>{{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
        {{/if}}

        {{#if (eq this.type "education")}}
        {{#each this.entries}}
        <div class="edu-row">
          <div>
            <div class="edu-inst">{{this.heading}}</div>
            {{#if this.subheading}}<div class="edu-degree">{{this.subheading}}</div>{{/if}}
            {{#if (hasItems this.bullets)}}
            <ul class="exp-bullets">
              {{#each this.bullets}}<li>{{this}}</li>{{/each}}
            </ul>
            {{/if}}
          </div>
          {{#if this.date}}<div class="edu-date">{{this.date}}</div>{{/if}}
        </div>
        {{/each}}
        {{/if}}

        {{#if (eq this.type "entries")}}
        {{#each this.entries}}
        <div class="exp-card">
          <div class="exp-top">
            <div>
              <div class="exp-role">{{this.heading}}</div>
              {{#if this.subheading}}<div class="exp-company">{{this.subheading}}</div>{{/if}}
            </div>
            {{#if this.date}}<div class="exp-date">{{this.date}}</div>{{/if}}
          </div>
          {{#if (hasItems this.bullets)}}
          <ul class="exp-bullets">
            {{#each this.bullets}}<li>{{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
        {{/if}}

      </section>
      {{/each}}

    </main>
  </div>
</body>
</html>
