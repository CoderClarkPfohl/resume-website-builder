<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Terminal</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="terminal">
    <div class="terminal-bar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
      <span class="bar-title">{{name}} — resume</span>
    </div>
    <div class="terminal-body">

      <div class="line"><span class="prompt">$</span> cat about.txt</div>
      <div class="output">
        <div class="ascii-name">{{name}}</div>
        <div class="contact-block">
          {{#if email}}<span>{{email}}</span>{{/if}}
          {{#if phone}}<span>{{phone}}</span>{{/if}}
          {{#if location}}<span>{{location}}</span>{{/if}}
          {{#if linkedin}}<span><a href="https://{{linkedin}}" target="_blank" rel="noopener">{{linkedin}}</a></span>{{/if}}
          {{#if github}}<span><a href="https://{{github}}" target="_blank" rel="noopener">{{github}}</a></span>{{/if}}
          {{#if website}}<span><a href="{{website}}" target="_blank" rel="noopener">{{website}}</a></span>{{/if}}
        </div>
      </div>

      {{#each activeSections}}
      <div class="line"><span class="prompt">$</span> cat {{this.key}}.txt</div>
      <div class="output">
        {{#if (eq this.type "text")}}
        <div class="summary">{{this.textContent}}</div>
        {{/if}}

        {{#if (eq this.type "list")}}
        <div class="skills-output">{{join this.listItems " · "}}</div>
        {{/if}}

        {{#if (eq this.type "experience")}}
        {{#each this.entries}}
        <div class="exp-block">
          <div class="exp-header">
            <span class="exp-title">{{this.heading}}</span>
            {{#if this.subheading}}<span class="exp-at">@ {{this.subheading}}</span>{{/if}}
            {{#if this.date}}<span class="exp-date">[{{this.date}}]</span>{{/if}}
          </div>
          {{#if (hasItems this.bullets)}}
          <ul class="exp-bullets">
            {{#each this.bullets}}<li><span class="bullet-arrow">→</span> {{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
        {{/if}}

        {{#if (eq this.type "education")}}
        {{#each this.entries}}
        <div class="edu-block">
          <span class="edu-inst">{{this.heading}}</span>
          {{#if this.subheading}}<span class="edu-degree"> — {{this.subheading}}</span>{{/if}}
          {{#if this.date}}<span class="exp-date"> [{{this.date}}]</span>{{/if}}
          {{#if (hasItems this.bullets)}}
          <ul class="exp-bullets">
            {{#each this.bullets}}<li><span class="bullet-arrow">→</span> {{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
        {{/if}}

        {{#if (eq this.type "entries")}}
        {{#each this.entries}}
        <div class="exp-block">
          <div class="exp-header">
            <span class="exp-title">{{this.heading}}</span>
            {{#if this.subheading}}<span class="exp-at">@ {{this.subheading}}</span>{{/if}}
            {{#if this.date}}<span class="exp-date">[{{this.date}}]</span>{{/if}}
          </div>
          {{#if (hasItems this.bullets)}}
          <ul class="exp-bullets">
            {{#each this.bullets}}<li><span class="bullet-arrow">→</span> {{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
        {{/if}}
      </div>
      {{/each}}

      <div class="line"><span class="prompt">$</span> <span class="cursor">_</span></div>
    </div>
  </div>
</body>
</html>
