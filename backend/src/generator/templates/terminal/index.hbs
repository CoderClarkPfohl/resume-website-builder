<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{name}} — Terminal</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="terminal">
    <div class="terminal-bar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
      <span class="bar-title">{{name}} — resume</span>
    </div>
    <div class="terminal-body">

      <div class="line"><span class="prompt">$</span> cat about.txt</div>
      <div class="output">
        <div class="ascii-name">{{name}}</div>
        <div class="contact-block">
          {{#if email}}<span>{{email}}</span>{{/if}}
          {{#if phone}}<span>{{phone}}</span>{{/if}}
          {{#if location}}<span>{{location}}</span>{{/if}}
          {{#if linkedin}}<span><a href="https://{{linkedin}}" target="_blank" rel="noopener">{{linkedin}}</a></span>{{/if}}
          {{#if website}}<span><a href="{{website}}" target="_blank" rel="noopener">{{website}}</a></span>{{/if}}
        </div>
      </div>

      {{#if summary}}
      <div class="line"><span class="prompt">$</span> cat summary.txt</div>
      <div class="output summary">{{summary}}</div>
      {{/if}}

      {{#if (hasItems experience)}}
      <div class="line"><span class="prompt">$</span> ls experience/</div>
      <div class="output">
        {{#each experience}}
        <div class="exp-block">
          <div class="exp-header">
            <span class="exp-title">{{title}}</span>
            <span class="exp-at">@ {{company}}</span>
            <span class="exp-date">[{{dateRange startDate endDate}}]</span>
          </div>
          {{#if location}}<div class="exp-loc">  // {{location}}</div>{{/if}}
          {{#if (hasItems bullets)}}
          <ul class="exp-bullets">
            {{#each bullets}}<li><span class="bullet-arrow">→</span> {{this}}</li>{{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if (hasItems education)}}
      <div class="line"><span class="prompt">$</span> ls education/</div>
      <div class="output">
        {{#each education}}
        <div class="edu-block">
          <span class="edu-inst">{{institution}}</span>
          {{#if degree}}<span class="edu-degree"> — {{degree}}{{#if field}} in {{field}}{{/if}}</span>{{/if}}
          {{#if startDate}}<span class="exp-date"> [{{dateRange startDate endDate}}]</span>{{/if}}
          {{#if gpa}}<div class="edu-gpa">  GPA: {{gpa}}</div>{{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if (hasItems skills)}}
      <div class="line"><span class="prompt">$</span> echo $SKILLS</div>
      <div class="output skills-output">{{join skills " · "}}</div>
      {{/if}}

      <div class="line"><span class="prompt">$</span> <span class="cursor">_</span></div>
    </div>
  </div>
</body>
</html>
